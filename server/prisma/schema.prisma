generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id   Int    @id @default(autoincrement())
  username String @unique
  email String @unique
  password String
  role RoleName
  version Int @default(1)
  createdAt DateTime @default(now())

}

enum RoleName {
  CANDIDATE
  RECRUITER
  ADMIN
} 

model Category {
  id Int @id @default(autoincrement())
  name String @unique
  attributes Attribute[]

}

enum AttributeType {
  STRING
  TEXT
  IMAGE
  NUMERIC
  DATE
  PERIOD
  BOOLEAN
  SELECT

}

model Attribute {
  id Int @id @default(autoincrement())
  name String @unique
  description String
  type AttributeType
  categoryId Int
  category Category @relation(fields: [categoryId], references: [id])
  version Int @default(1)
  createdAt DateTime @default(now())

}
