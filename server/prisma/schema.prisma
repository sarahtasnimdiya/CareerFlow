generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id   Int    @id @default(autoincrement())
  username String @unique
  email String @unique
  password String
  role RoleName
  version Int @default(1)
  createdAt DateTime @default(now())
  profileValues ProfileValue[]
  projects Project[]
  cvs CV[]
}

enum RoleName {
  CANDIDATE
  RECRUITER
  ADMIN
} 

model Category {
  id Int @id @default(autoincrement())
  name String @unique
  attributes Attribute[]

}

enum AttributeType {
  STRING
  TEXT
  IMAGE
  NUMERIC
  DATE
  PERIOD
  BOOLEAN
  SELECT

}

model Attribute {
  id Int @id @default(autoincrement())
  name String @unique
  description String
  type AttributeType
  categoryId Int
  category Category @relation(fields: [categoryId], references: [id])
  version Int @default(1)
  createdAt DateTime @default(now())
  positions PositionAttribute[]
  accessRules AccessRule[]
  profileValues ProfileValue[]
  isBuiltIn Boolean @default(false)
}

model Position {
  id Int @id @default(autoincrement())
  title String
  shortDescription String
  isPublic Boolean @default(true)
  projectTags String[]
  maxProjects Int @default(3)
  version Int @default(1)
  createdAt DateTime @default(now())
  attributes PositionAttribute[]
  accessRules AccessRule[]
  cvs CV[]
}

model PositionAttribute {
  id Int @id @default(autoincrement())
  positionId Int 
  position Position @relation(fields: [positionId], references: [id], onDelete: Cascade)
  attributeId Int
  attribute Attribute @relation(fields: [attributeId], references: [id])
  
}

model AccessRule {
  id Int @id @default(autoincrement())
  positionId Int
  position Position @relation(fields: [positionId], references: [id], onDelete: Cascade)
  attributeId Int
  attribute Attribute @relation(fields: [attributeId], references: [id])
  operator String
  value String
}

model ProfileValue {
  id Int @id @default(autoincrement())
  userId Int
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  attributeId Int
  attribute Attribute @relation(fields: [attributeId], references: [id])
  value String
  version Int @default(1)
  updatedAt DateTime @updatedAt

  @@unique([userId, attributeId])
}

model Project {
  id Int @id @default(autoincrement())
  userId Int
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  name String
  startDate DateTime
  endDate DateTime?
  description String
  tags String[]
  version Int @default(1)
  createdAt DateTime @default(now())
}

model CV {
  id Int @id @default(autoincrement())
  userId Int
  user User @relation(fields: [userId], references: [id], onDelete:Cascade)
  positionId Int
  position Position @relation(fields:[positionId], references: [id], onDelete: Cascade)
  isPublished Boolean @default(false)
  createdAt DateTime @default(now())

  @@unique([userId, positionId])
}